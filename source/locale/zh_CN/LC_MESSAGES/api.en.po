#: ../api.en.rst:29
msgid "Compilation Pipeline"
msgstr ""

#: ../api.en.rst:30
msgid ""
"``QASM source file → Preprocessing → MLIR (Quantum dialect) → "
"Optimization Passes → Lowering → LLVM IR (QIR) → Backend emission``"
msgstr ""

#: ../api.en.rst:33
msgid "Technical Route"
msgstr ""

#: ../api.en.rst:34
msgid ""
"Front-end: Responsible for language parsing and intermediate code "
"generation, converting high-level languages to MLIR Quantum dialect"
msgstr ""

#: ../api.en.rst:35
msgid ""
"Middle-end: Perform quantum program optimization based on MLIR, and "
"further lower MLIR to QIR (LLVM IR)"
msgstr ""

#: ../api.en.rst:36
msgid ""
"Back-end: Based on QIR and QIR runtime library, convert programs to code "
"formats supported by target hardware"
msgstr ""

#: ../api.en.rst:39
msgid "Key Advantages"
msgstr ""

#: ../api.en.rst:40
msgid ""
"Industrial-grade IR infrastructure: Based on MLIR/LLVM, easy to extend "
"new dialects and new passes"
msgstr ""

#: ../api.en.rst:41
msgid ""
"Multiple input forms: OpenQASM, Qiskit, Q# etc., adapting to different "
"programming habits"
msgstr ""

#: ../api.en.rst:42
msgid ""
"Flexible optimization: -O0/-O1 levels, custom pass sequences, synthesis "
"optimization"
msgstr ""

#: ../api.en.rst:43
msgid ""
"Physical constraint mapping: SABRE and other layout and SWAP strategies, "
"adapting to real hardware topology"
msgstr ""

