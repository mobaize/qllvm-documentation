#: ../contributing.en.rst:141
msgid "Code Style"
msgstr ""

#: ../contributing.en.rst:143
msgid "The QLLVM project follows the following code style:"
msgstr ""

#: ../contributing.en.rst:145
msgid ""
"**Python code**: Follow PEP 8 guidelines - Use 4 spaces for indentation -"
" Line length does not exceed 79 characters - Import order: standard "
"library, third-party libraries, local modules - Use docstrings to "
"document functions and classes"
msgstr ""

#: ../contributing.en.rst:151
msgid ""
"**Documentation**: Follow reStructuredText format - Use clear heading "
"hierarchy - Code examples use correct syntax highlighting - Links use "
"relative paths"
msgstr ""

#: ../contributing.en.rst:156
msgid ""
"**Commit messages**: Use clear commit messages - First line: short "
"description (no more than 50 characters) - Empty line - Detailed "
"description (if needed) - Reference related Issues (if any)"
msgstr ""

